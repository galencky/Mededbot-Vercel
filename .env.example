# Vertex AI (replaces Gemini API key)
# Base64-encoded service account JSON:
#   base64 -i path/to/key.json | pbcopy
GOOGLE_CREDS_B64=
# Optional: override project id from the service account JSON
VERTEX_PROJECT_ID=
# Default us-central1 (required for preview TTS model)
VERTEX_LOCATION=us-central1

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Neon Postgres
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Upstash Redis (session store)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (audio + text artifacts)
BLOB_READ_WRITE_TOKEN=

# Gmail SMTP
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Cron protection
CRON_SECRET=

# Optional
LOG_LEVEL=info
